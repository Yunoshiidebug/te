<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<title>GTA SA PaintJobs Shop</title>

<style>
body {
    margin: 0;
    font-family: Arial;
    background: #0d0d0d;
    color: white;
}

/* HEADER */
header {
    background: linear-gradient(90deg, #ff3c00, #ff9900);
    padding: 30px;
    text-align: center;
}

h1 {
    margin: 0;
    font-size: 40px;
}

/* SEKCJE */
.section {
    padding: 40px;
}

.section h2 {
    border-bottom: 2px solid #ff3c00;
    padding-bottom: 10px;
}

/* GALERIA */
.gallery {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
}

.item {
    background: #1a1a1a;
    border-radius: 10px;
    overflow: hidden;
    width: 250px;
    transition: 0.3s;
}

.item:hover {
    transform: scale(1.05);
}

.item img {
    width: 100%;
    height: 150px;
    object-fit: cover;
}

.caption {
    padding: 10px;
    font-size: 14px;
    text-align: center;
}

/* STOPKA */
footer {
    text-align: center;
    padding: 20px;
    background: #111;
    color: #888;
}
</style>
</head>

<body>

<header>
    <h1>🔥 GTA SA PaintJobs Shop</h1>
    <p>Najlepsze paintjoby do Twoich fur 🔥</p>
</header>

<!-- SULTAN -->
<div class="section">
    <h2>🚗 Sultan</h2>
    <div class="gallery">

        <!-- DODAWANIE ZDJĘCIA -->
        <div class="item">
            <img src="LINK_DO_ZDJECIA" alt="">
            <div class="caption">Opis paintjoba Sultan</div>
        </div>

    </div>
</div>

<!-- ELEGY -->
<div class="section">
    <h2>🚗 Elegy</h2>
    <div class="gallery">
        <div class="item">
            <img src="LINK_DO_ZDJECIA" alt="">
            <div class="caption">Opis paintjoba Elegy</div>
        </div>
    </div>
</div>

<!-- BURRITO -->
<div class="section">
    <h2>🚐 Burrito</h2>
    <div class="gallery">
        <div class="item">
            <img src="LINK_DO_ZDJECIA" alt="">
            <div class="caption">Opis paintjoba Burrito</div>
        </div>
    </div>
</div>

<!-- FLASH -->
<div class="section">
    <h2>🚗 Flash</h2>
    <div class="gallery">
        <div class="item">
            <img src="LINK_DO_ZDJECIA" alt="">
            <div class="caption">Opis paintjoba Flash</div>
        </div>
    </div>
</div>

<!-- TURISMO -->
<div class="section">
    <h2>🏎 Turismo</h2>
    <div class="gallery">
        <div class="item">
            <img src="LINK_DO_ZDJECIA" alt="">
            <div class="caption">Opis paintjoba Turismo</div>
        </div>
    </div>
</div>

<!-- BUFFALO -->
<div class="section">
    <h2>🚗 Buffalo</h2>
    <div class="gallery">
        <div class="item">
            <img src="LINK_DO_ZDJECIA" alt="">
            <div class="caption">Opis paintjoba Buffalo</div>
        </div>
    </div>
</div>

<!-- ALPHA -->
<div class="section">
    <h2>🚗 Alpha</h2>
    <div class="gallery">
        <div class="item">
            <img src="LINK_DO_ZDJECIA" alt="">
            <div class="caption">Opis paintjoba Alpha</div>
        </div>
    </div>
</div>

<!-- WKRÓTCE -->
<div class="section">
    <h2>⏳ Więcej wkrótce...</h2>
    <p>Nowe auta i paintjoby już niedługo 🔥</p>
</div>

<footer>
    <p>© 2026 GTA SA PaintJobs Shop</p>
</footer>

</body>
</html>
